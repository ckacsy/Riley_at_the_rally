PORT=5000
NODE_ENV=development
RASPBERRY_PI_HOST=localhost
RASPBERRY_PI_PORT=8000
CAMERA_STREAM_PORT=8000
DEBUG=true
SESSION_SECRET=change-this-to-a-long-random-string
APP_BASE_URL=http://localhost:5000
# Session duration limit in milliseconds (default: 600000 = 10 minutes)
SESSION_MAX_DURATION_MS=600000
# Max control commands per second per socket before rate-limiting (default: 20)
CONTROL_RATE_LIMIT_MAX=20

# --- Health checks ---
# Optional URL to test camera stream reachability in /api/health (e.g. http://raspberrypi.local:8000)
CAMERA_STREAM_URL=

# --- Metrics ---
# Secret key required to access /api/metrics in production (set x-metrics-key header)
METRICS_SECRET=change-this-to-a-random-secret

# --- Alerts ---
# Errors per minute threshold before an alert fires (default: 10)
ALERT_ERROR_THRESHOLD=10
# Optional webhook URL to POST alert payloads to (leave blank to use console-only alerts)
ALERT_WEBHOOK_URL=