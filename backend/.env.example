# ============================================================
# Riley at the Rally — Backend Environment Variables Example
# Copy this file to .env and fill in your own values.
# ============================================================

# --- Application ---
# Base URL used in email links (set to your public domain in production)
APP_BASE_URL=https://your-domain.com

# Set to 'production' for live deployment
NODE_ENV=production

# Port the backend listens on (default: 5000)
# PORT=5000

# --- Database ---
# Path to the SQLite database file (default: riley.sqlite)
# DB_PATH=riley.sqlite

# --- Session ---
# Secret used to sign session cookies — change this to a long random string!
# SESSION_SECRET=change-me-to-a-random-string

# --- DNS (fixes resolution issues behind VPN/Docker/WSL) ---
# Override the DNS servers used by Node.js. Comma-separated list of IPs.
# DNS_SERVERS=8.8.8.8,8.8.4.4

# --- Email / SMTP Configuration ---
# To send real emails (e.g. via Gmail), configure SMTP below.
# For Gmail you must use an App Password (not your normal Gmail password).
# See INSTALL.md → "Email Configuration" for step-by-step instructions.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Set to 'true' only when using port 465 (SSL). Leave 'false' for port 587 (STARTTLS).
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM="Riley RC" <your-email@gmail.com>

# Set to 'true' to disable email sending entirely.
# When disabled, email content (including verification/magic-link URLs) is
# printed to the server console instead of being delivered.
# Automatically enabled when NODE_ENV=test.
DISABLE_EMAIL=false

# --- Admin ---
# Comma-separated list of usernames with admin privileges
# ADMIN_USERNAMES=admin

# --- Metrics ---
# Secret key required to access /api/metrics (optional)
# METRICS_SECRET=change-me

# --- Camera ---
# URL of the MJPEG camera stream served by the Raspberry Pi (optional)
# CAMERA_STREAM_URL=http://<pi-ip>:8000/stream.mjpg

# --- Alerts ---
# Webhook URL for fireAlert notifications (optional)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
