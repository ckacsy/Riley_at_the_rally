# ============================================================
#  Riley at the Rally — Переменные окружения (шаблон)
#
#  Скопируйте этот файл в .env и заполните собственными
#  значениями. Файл .env НЕ коммитится в Git (добавлен
#  в .gitignore) — храните в нём реальные секреты.
#
#    cp .env.example .env
#
# ============================================================

# ========================
#  Приложение
# ========================

# Базовый URL, который подставляется в ссылки в письмах
# (верификация email, magic-link, сброс пароля).
# В продакшене укажите ваш публичный домен.
# Если не задан — используется протокол и хост из входящего запроса.
# APP_BASE_URL=https://your-domain.com

# Режим работы приложения:
#   development — подробные логи, dev-эндпоинты (/api/dev/*) включены
#   production  — минимальные логи, dev-эндпоинты отключены
#   test        — используется при запуске тестов (email отключается автоматически)
NODE_ENV=development

# Порт, на котором запускается HTTP-сервер.
# По умолчанию: 5000
# PORT=5000

# ========================
#  База данных (SQLite)
# ========================

# Путь к файлу базы данных SQLite.
# По умолчанию: riley.sqlite (в корне проекта).
# DB_PATH=riley.sqlite

# ========================
#  Сессии
# ========================

# Секретный ключ для подписи cookie сессий.
# ОБЯЗАТЕЛЬНО замените на длинную случайную строку!
# Сгенерировать можно командой:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=a3f1b9c7e8dyofekm1659234hjroqmfng[a[wpttk44921111

# ========================
#  DNS (необязательно)
# ========================

# Принудительная установка DNS-серверов для Node.js.
# Полезно, если вы работаете за VPN, в Docker или WSL
# и стандартный резолвер не может найти SMTP-хост.
# Перечислите IP через запятую.
DNS_SERVERS=8.8.8.8,8.8.4.4

# ========================
#  Email / SMTP
# ========================

# Настройки SMTP-сервера для отправки писем
# (верификация email, magic-link авторизация, сброс пароля).
#
# Для Gmail нужен «пароль приложения», а НЕ обычный пароль от аккаунта.
# Инструкция: INSTALL.md → раздел «Email Configuration».
#
# Если вы не хотите настраивать SMTP — установите DISABLE_EMAIL=true,
# тогда ссылки будут выводиться в консоль сервера.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Использовать SSL (порт 465) вместо STARTTLS (порт 587)?
# Установите true только для порта 465.
SMTP_SECURE=false

# Логин и пароль приложения для SMTP-авторизации.
# ⚠️  НЕ вписывайте реальные данные в .env.example!
#     Заполните эти поля только в .env.
SMTP_USER=
SMTP_PASS=

# Если вы подключаетесь к SMTP по IP-адресу (например, для обхода DNS),
# укажите реальное имя хоста для валидации TLS-сертификата.
# SMTP_TLS_SERVERNAME=smtp.gmail.com

# Имя и адрес отправителя в письмах.
MAIL_FROM="Riley RC" <clacsy8644@gmail.com>

# Полностью отключить отправку email.
# Когда true — содержимое писем (включая ссылки верификации и magic-link)
# выводится в консоль сервера вместо реальной отправки.
# Автоматически включается при NODE_ENV=test.
DISABLE_EMAIL=false


# ========================
#  Администрирование
# ========================

# Список логинов с правами администратора (через запятую, без пробелов).
# Эти пользователи получают доступ к /admin, могут банить, удалять сообщения и т.д.
ADMIN_USERNAMES=myadmin

# ========================
#  Метрики
# ========================

# Секретный ключ для доступа к эндпоинту /api/metrics.
# Если не задан — эндпоинт метрик доступен без авторизации.
# METRICS_SECRET=замените-на-случайную-строку

# ========================
#  Камера (Raspberry Pi)
# ========================

# URL MJPEG-потока камеры, установленной на RC-машине.
# Обычно это Raspberry Pi с модулем камеры и MJPEG-стримером.
# Пример: http://192.168.1.50:8000/stream.mjpg
# CAMERA_STREAM_URL=http://<ip-raspberry-pi>:8000/stream.mjpg

# ========================
#  Оповещения (вебхуки)
# ========================

# URL вебхука для отправки уведомлений (например, при критических ошибках).
# Поддерживается Slack Incoming Webhook, Discord Webhook и т.п.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
